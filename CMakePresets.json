{
  "version": 3,
  "configurePresets": [
    {
      "name": "nix-clang",
      "displayName": "Nix Clang",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build",
      "cacheVariables": {
        "CMAKE_CXX_COMPILER": "clang++",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "nix-clang",
      "configurePreset": "nix-clang"
    }
  ]
}
